{
  "description": "Guardrails for e2e-testing: block Edit/Write on the source checklist file during an active /run-checklist run.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/guard-source-file.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
