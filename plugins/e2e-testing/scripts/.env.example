# Copy to .env.local (gitignored) and fill in your real values.
# Loaded automatically by the runner if python-dotenv is installed.

# OpenAI-compatible base URL of the local model server (LM Studio, vLLM, ...).
# Use http:// unless your endpoint terminates TLS.
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1

# Model id as exposed by GET /v1/models (must support vision + tool calling).
LMSTUDIO_MODEL=nvidia/nemotron-3-nano-omni

# Optional API key — LM Studio ignores it; some proxies require it.
LMSTUDIO_API_KEY=lm-studio
